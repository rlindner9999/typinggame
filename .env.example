# Server wallet — this account must own the deployed contract (operator)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed TypeRacerGame contract address (fill in after running deploy script)
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Base Sepolia RPC — default public endpoint works fine for low traffic
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Port for the game server
PORT=3000
